    <script>
        const i18n = {
            id: {
                titleFunds: '💰 TOTAL DANA TERSALURKAN SEJAK 6 JANUARI 2025',
                titleSummary: '📊 Ringkasan Program Nasional',
                subtitleSummary: 'Jangkauan dan dampak program makan bergizi gratis di seluruh Indonesia',
                labelSppg: 'Dapur Beroperasi',
                labelBeneficiaries: 'Penerima Manfaat',
                labelJobs: 'Lapangan Kerja',
                labelSchools: 'Sekolah',
                labelProvinces: 'Provinsi',
                labelKabupaten: 'Kabupaten/Kota',
                titleBeneficiary: '👥 Rincian Penerima Manfaat',
                subtitleBeneficiary: 'Segmentasi program menurut kategori penerima manfaat',
                labelTotalBeneficiaries: 'Penerima Manfaat Total',
                labelStudents: 'Siswa Sekolah',
                labelMothers: 'Ibu Hamil & Menyusui',
                labelToddlers: 'Balita (0-59 Bulan)',
                titleMap: 'Sebaran SPPG Seluruh Indonesia',
                subtitleMap: 'Klik provinsi untuk lihat detail kabupaten/kota',
                legendLow: 'Rendah',
                legendHigh: 'Tinggi',
                navDashboard: 'Dashboard',
                navSustainableImpact: 'Dampak Berkelanjutan',
                heroMemberiMakan: 'Memberi Makan',
                heroAnakBangsa: 'Anak Bangsa Setiap Hari',
                selectProvince: 'Pilih Provinsi',
                selectProvinceSearch: '🔍 Pilih Provinsi...',
                selectProvinceOption: '— Pilih Provinsi —',
                detailTitle: 'Pilih Provinsi',
                progressTitle: '📈 Progress MBG',
                progressDesc: 'Data capaian program Makan Bergizi Gratis secara nasional',
                summaryTitle: '📊 Ringkasan Nasional',
                summaryDesc: 'Jangkauan dan dampak program makan bergizi gratis di seluruh Indonesia',
                placeholderProvinceSearch: 'Ketik nama provinsi...',
                langIndonesia: 'Bahasa Indonesia',
                langEnglish: 'English'
            },
            en: {
                titleFunds: '💰 TOTAL FUNDS DISBURSED SINCE JANUARY 6, 2025',
                titleSummary: '📊 National Program Summary',
                subtitleSummary: 'Reach and impact across Indonesia',
                labelSppg: 'Operating Kitchens',
                labelBeneficiaries: 'Beneficiaries',
                labelJobs: 'Job Opportunities',
                labelSchools: 'Schools',
                labelProvinces: 'Provinces',
                labelKabupaten: 'Districts/Cities',
                titleBeneficiary: '👥 Beneficiary Details',
                subtitleBeneficiary: 'Program segmentation by category',
                labelTotalBeneficiaries: 'Total Beneficiaries',
                labelStudents: 'School Students',
                labelMothers: 'Pregnant & Nursing Mothers',
                labelToddlers: 'Toddlers (0-59 Months)',
                titleMap: 'SPPG Distribution Across Indonesia',
                subtitleMap: 'Click a province to see district/city details',
                legendLow: 'Low',
                legendHigh: 'High',
                navDashboard: 'Dashboard',
                navSustainableImpact: 'Sustainable Impact',
                heroMemberiMakan: 'Feeding',
                heroAnakBangsa: 'Children of the Nation Every Day',
                selectProvince: 'Select Province',
                selectProvinceSearch: '🔍 Select Province...',
                selectProvinceOption: '— Select Province —',
                detailTitle: 'Select Province',
                progressTitle: '📈 MBG Progress',
                progressDesc: 'National achievement data for the Free Nutritious Meals program',
                summaryTitle: '📊 National Program Summary',
                summaryDesc: 'Reach and impact of the free nutritious meals program across Indonesia',
                placeholderProvinceSearch: 'Type province name...',
                langIndonesia: 'Bahasa Indonesia',
                langEnglish: 'English'
            }
        };

        let currentLang = 'id';

        function switchLanguage(lang) {
            currentLang = lang;
            const flag = lang === 'id' ? '🇮🇩' : '🇬🇧';
            const name = lang === 'id' ? 'Bahasa Indonesia' : 'English';
            document.getElementById('lang-flag').textContent = flag;
            document.getElementById('lang-text').textContent = name;

            // Close the language menu
            const menu = document.getElementById('lang-menu');
            if (menu) menu.classList.remove('open');

            // Update all translatable elements
            const translations = i18n[lang];
            const idMap = {
                'titleSummary': 'summaryTitle',
                'subtitleSummary': 'summaryDesc',
                'titleBeneficiary': 'title-beneficiary',
                'subtitleBeneficiary': 'subtitle-beneficiary',
                'titleMap': 'title-map',
                'subtitleMap': 'subtitle-map'
            };

            Object.keys(translations).forEach(key => {
                const htmlId = idMap[key] || key;
                const el = document.getElementById(htmlId);
                if (el) {
                    el.textContent = translations[key];
                }
            });

            // Update specific select option text
            const selectOption = document.getElementById('selectProvinceSearch');
            if (selectOption) {
                selectOption.textContent = translations.selectProvinceSearch;
            }

            // Update nav button texts
            const navDash = document.getElementById('navDashboard');
            if (navDash) navDash.textContent = translations.navDashboard;
            const navSustain = document.getElementById('navSustainableImpact');
            if (navSustain) navSustain.textContent = translations.navSustainableImpact;

            // Update hero sections
            const heroMakan = document.getElementById('heroMemberiMakan');
            if (heroMakan) heroMakan.textContent = translations.heroMemberiMakan;
            const heroBangsa = document.getElementById('heroAnakBangsa');
            if (heroBangsa) heroBangsa.textContent = translations.heroAnakBangsa;

            // Update progress badge
            const progressBadge = document.getElementById('progressBadge');
            if (progressBadge) progressBadge.textContent = translations.progressTitle;

            // Update all stat labels
            const labelIds = ['label-sppg', 'label-beneficiaries', 'label-jobs', 'label-schools', 'label-provinces', 'label-kabupaten'];
            const labelKeys = ['labelSppg', 'labelBeneficiaries', 'labelJobs', 'labelSchools', 'labelProvinces', 'labelKabupaten'];
            labelIds.forEach((id, idx) => {
                const el = document.getElementById(id);
                if (el && translations[labelKeys[idx]]) {
                    el.textContent = translations[labelKeys[idx]];
                }
            });

            // Update beneficiary detail labels
            const beneficiaryLabels = ['labelTotalBeneficiaries', 'labelStudents', 'labelMothers', 'labelToddlers'];
            beneficiaryLabels.forEach(key => {
                const el = document.getElementById(key);
                if (el && translations[key]) {
                    el.textContent = translations[key];
                }
            });

            // Update legend
            const legendLow = document.getElementById('legend-low');
            if (legendLow) legendLow.textContent = translations.legendLow;
            const legendHigh = document.getElementById('legend-high');
            if (legendHigh) legendHigh.textContent = translations.legendHigh;
        }

        function toggleLanguage() {
            const menu = document.getElementById('lang-menu');
            if (menu) {
                menu.classList.toggle('open');
            }
        }

        function formatNumber(n) {
            if (n >= 1000000000) return (n / 1000000000).toFixed(1).replace('.', ',') + 'B';
            if (n >= 1000000) return (n / 1000000).toFixed(1).replace('.', ',') + 'M';
            return n.toLocaleString('id-ID');
        }

        const startDate = new Date('2025-01-06T07:00:00+07:00');

        function countWorkingDays(start, end) {
            let count = 0;
            let d = new Date(start);
            while (d <= end) {
                const dow = d.getDay();
                if (dow !== 0 && dow !== 6) count++;
                d.setDate(d.getDate() + 1);
            }
            return count;
        }

        function updateTicker() {
            const now = new Date();
            const diff = now - startDate;
            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((diff % (1000 * 60)) / 1000);

            document.getElementById('days').textContent = String(days).padStart(2, '0');
            document.getElementById('hours').textContent = String(hours).padStart(2, '0');
            document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
            document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');

            // Update total meals served (beneficiaries × working days)
            const workDays = countWorkingDays(startDate, now);
            const totalMeals = 76485000 * workDays;
            const mealsEl = document.getElementById('meals');
            if (mealsEl) mealsEl.textContent = totalMeals.toLocaleString('id-ID');
        }

        function showNationalData() {
            const nat = DATA.national;
            document.getElementById('sidebar-title').textContent = '🇮🇩 Indonesia';
            document.getElementById('sidebar-breadcrumb').innerHTML = '<span style="color:var(--text-muted);">Dashboard Nasional</span>';
            document.getElementById('sb-sppg').textContent = fmtNum(nat.sppg);
            document.getElementById('sb-beneficiaries').textContent = fmtNum(nat.beneficiaries);
            document.getElementById('sb-schools').textContent = fmtNum(nat.schools);
            document.getElementById('sb-fund').textContent = fmtRp(nat.totalFund * 1000);
            document.getElementById('sb-students').textContent = fmtNum(nat.students);
            document.getElementById('sb-mothers').textContent = fmtNum(nat.mothers);
            document.getElementById('sb-toddlers').textContent = fmtNum(nat.toddlers);
            document.getElementById('sb-kitchen').textContent = fmtNum(nat.kitchenWorkers);
            document.getElementById('sb-suppliers').textContent = fmtNum(nat.suppliers);
            document.getElementById('sb-entrepreneurs').textContent = fmtNum(nat.entrepreneurs);
            document.getElementById('sb-sdm').textContent = fmtNum(nat.totalJobs);
            document.getElementById('sb-commodity').textContent = fmtRp(nat.mCommodity * 1000);
            document.getElementById('sb-worker-cost').textContent = fmtRp(nat.mWorker * 1000);
            document.getElementById('sb-transport').textContent = fmtRp(nat.mTransport * 1000);
            document.getElementById('sb-alloc').textContent = fmtRp(nat.mTotal * 1000);
            document.getElementById('sb-monthly-tons').textContent = fmtNum(Math.round(nat.monthlyTons)) + ' ton';
            document.getElementById('sb-sub-title').textContent = '📊 Ringkasan Provinsi';
            document.getElementById('sb-kab-list').innerHTML = '';
            document.getElementById('sb-kec-section').classList.add('hidden');
        }

        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.body.classList.remove('sidebar-push');
        }
        function showSidebar() {
            document.getElementById('sidebar').classList.add('open');
            document.body.classList.add('sidebar-push');
        }

        function switchTab(e, tabName) {
            document.querySelectorAll('.tab-pill').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            e.target.classList.add('active');
            document.getElementById('tab-' + tabName).classList.add('active');
        }

        function shareLink(type) {
            const url = window.location.href;
            if (type === 'copy') {
                navigator.clipboard.writeText(url);
                alert('Link copied!');
            } else if (type === 'twitter') {
                window.open(`https://twitter.com/intent/tweet?text=Manfaat MBG Dashboard&url=${url}`, '_blank');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateTicker();
            setInterval(updateTicker, 1000);
        });
    
