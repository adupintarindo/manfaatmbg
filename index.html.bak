<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manfaat MBG - Program Makan Bergizi Gratis Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Playfair+Display:wght@700;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-warm: #FAF7F2;
            --bg-dark: #16697A;
            --bg-card: #FFFFFF;
            --primary: #16697A;
            --primary-light: #489FB5;
            --accent-red: #E63946;
            --accent-gold: #FCA311;
            --accent-green: #2D6A4F;
            --accent-pink: #E56B6F;
            --accent-orange: #F4845F;
            --text-dark: #2B2D42;
            --text-muted: #8D99AE;
            --border: #EDE8E0;
            --border-light: #F0EDEA;
            --glass-bg: rgba(255, 255, 255, 0.55);
            --glass-border: rgba(255, 255, 255, 0.65);
            --glass-shadow: 0 8px 32px rgba(22, 105, 122, 0.08);
            --glass-blur: blur(16px);
        }

        .hidden { display: none !important; }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
            background-color: var(--bg-warm);
            color: var(--text-dark);
            line-height: 1.6;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Instrument Serif', 'Playfair Display', Georgia, serif;
            font-weight: 400;
            letter-spacing: -0.5px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* HEADER */
        header {
            position: sticky;
            top: 0;
            z-index: 200;
            background: linear-gradient(135deg, #16697A 0%, #489FB5 100%);
            border-bottom: 1px solid rgba(255, 255, 255, 0.15);
            box-shadow: 0 2px 12px rgba(22, 105, 122, 0.15);
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 40px;
        }

        .logo {
            font-family: 'Instrument Serif', 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 400;
            color: white;
            white-space: nowrap;
            letter-spacing: -0.5px;
        }

        nav {
            flex: 1;
            display: flex;
            justify-content: center;
            gap: 12px;
        }

        .nav-pill {
            padding: 8px 20px;
            border-radius: 24px;
            border: 1px solid transparent;
            background: transparent;
            color: rgba(255, 255, 255, 0.7);
            font-weight: 500;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .nav-pill:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .nav-pill.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .lang-selector {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.15);
            cursor: pointer;
            font-weight: 500;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
        }

        .lang-selector:hover {
            background: rgba(255, 255, 255, 0.15);
            color: white;
        }

        .lang-menu {
            position: absolute;
            top: 100%;
            right: 0;
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
            border: 1px solid var(--border);
            overflow: hidden;
            display: none;
            z-index: 300;
            min-width: 180px;
            margin-top: 8px;
        }

        .lang-menu.open {
            display: block;
        }

        .lang-option {
            padding: 12px 16px;
            cursor: pointer;
            font-size: 14px;
            transition: background 0.2s;
            color: var(--text-dark);
            font-weight: 500;
        }

        .lang-option:hover {
            background: rgba(22, 105, 122, 0.06);
        }

        .lang-option:active {
            background: rgba(22, 105, 122, 0.12);
        }

        /* HERO TICKER */
        .hero-ticker {
            background: var(--bg-warm);
            color: var(--text-dark);
            padding: 100px 24px 80px;
            margin-top: 0;
            position: relative;
            overflow: hidden;
        }

        .hero-ticker::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(ellipse at 30% 50%, rgba(252, 163, 17, 0.06) 0%, transparent 60%),
                        radial-gradient(ellipse at 70% 30%, rgba(210, 180, 140, 0.04) 0%, transparent 50%);
            pointer-events: none;
        }

        .ticker-content {
            max-width: 1400px;
            margin: 0 auto;
            text-align: center;
        }

        .live-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(230, 57, 70, 0.1);
            border: 1px solid var(--accent-red);
            color: var(--accent-red);
            padding: 8px 16px;
            border-radius: 20px;
            margin-bottom: 24px;
            font-weight: 600;
            font-size: 12px;
        }

        .live-dot {
            width: 8px;
            height: 8px;
            background: var(--accent-red);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        .ticker-title {
            font-size: 14px;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 16px;
            letter-spacing: 0.5px;
        }

        .main-counter {
            margin: 32px 0;
        }

        .counter-label {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 12px;
        }

        .counter-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 56px;
            font-weight: 700;
            color: var(--accent-gold);
            text-shadow: 0 0 20px rgba(252, 163, 17, 0.3);
            margin-bottom: 40px;
            letter-spacing: -1px;
        }

        .elapsed-time {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
            gap: 12px;
            margin-bottom: 48px;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
        }

        .time-card {
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 16px;
            padding: 20px 16px;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            transition: all 0.3s ease;
        }

        .time-card:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .time-card-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 32px;
            font-weight: 700;
            color: var(--accent-gold);
            line-height: 1;
            margin-bottom: 8px;
        }

        .time-card-label {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.6);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .rate-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 16px;
            margin-bottom: 40px;
        }

        .rate-card {
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 16px;
            padding: 24px 20px;
            text-align: center;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            transition: all 0.3s ease;
        }

        .rate-card:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }

        .rate-card-icon {
            font-size: 28px;
            margin-bottom: 8px;
        }

        .rate-card-label {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.6);
            margin-bottom: 8px;
            font-weight: 500;
        }

        .rate-card-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 16px;
            font-weight: 700;
            color: white;
        }

        .secondary-counters {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 12px;
            margin-bottom: 40px;
        }

        .secondary-card {
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 16px;
            text-align: center;
            backdrop-filter: blur(10px);
        }

        .secondary-card-icon {
            font-size: 24px;
            margin-bottom: 8px;
        }

        .secondary-card-label {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.6);
            margin-bottom: 8px;
            font-weight: 500;
        }

        .secondary-card-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 18px;
            font-weight: 700;
            color: white;
        }

        .share-buttons {
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 40px;
        }

        .share-btn {
            padding: 10px 20px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            background: rgba(255, 255, 255, 0.06);
            color: white;
            cursor: pointer;
            font-weight: 500;
            font-size: 13px;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }

        .share-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.5);
        }

        /* SECTION STYLING */
        section {
            padding: 80px 24px;
            animation: fadeInUp 0.8s ease-out;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section-title {
            font-family: 'Instrument Serif', 'Playfair Display', serif;
            font-size: 40px;
            font-weight: 400;
            color: var(--text-dark);
            margin-bottom: 12px;
            letter-spacing: -1px;
            line-height: 1.1;
        }

        .section-subtitle {
            font-size: 15px;
            color: var(--text-muted);
            margin-bottom: 36px;
        }

        .summary-cards-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 0;
        }

        .stat-card {
            background: var(--glass-bg);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border-radius: 20px;
            padding: 32px 28px;
            border: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
            transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
            display: flex;
            flex-direction: column;
            gap: 8px;
            text-align: center;
            align-items: center;
        }

        .stat-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 48px rgba(22, 105, 122, 0.15);
            border-color: rgba(22, 105, 122, 0.3);
        }

        .stat-icon {
            font-size: 36px;
            margin-bottom: 4px;
        }

        .stat-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 36px;
            font-weight: 700;
            color: var(--text-dark);
            letter-spacing: -1px;
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .beneficiary-section {
            background: var(--bg-warm);
        }

        .beneficiary-hero {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: white;
            border-radius: 24px;
            padding: 56px 48px;
            text-align: center;
            margin-bottom: 40px;
            box-shadow: 0 12px 48px rgba(22, 105, 122, 0.25);
            position: relative;
            overflow: hidden;
        }

        .beneficiary-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 50%, rgba(255,255,255,0.12) 0%, transparent 70%);
            pointer-events: none;
        }

        .beneficiary-hero-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 16px;
        }

        .beneficiary-hero-label {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.9);
        }

        .beneficiary-breakdown {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 24px;
        }

        .gradient-card {
            border-radius: 20px;
            padding: 36px 32px;
            color: white;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
            transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .gradient-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 60%);
            pointer-events: none;
        }

        .gradient-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.18);
        }

        .gradient-card.blue {
            background: linear-gradient(135deg, #3B82F6 0%, #1F79CB 100%);
        }

        .gradient-card.pink {
            background: linear-gradient(135deg, #E56B6F 0%, #D04D52 100%);
        }

        .gradient-card.orange {
            background: linear-gradient(135deg, #F4845F 0%, #E06745 100%);
        }

        .gradient-card-icon {
            font-size: 40px;
            margin-bottom: 16px;
        }

        .gradient-card-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .gradient-card-label {
            font-size: 14px;
            margin-bottom: 12px;
        }

        .gradient-card-percent {
            font-size: 18px;
            font-weight: 700;
        }

        .map-section {
            background: var(--bg-warm);
        }

        .map-container {
            background: var(--glass-bg);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border-radius: 24px;
            padding: 32px;
            border: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
            margin-bottom: 0;
        }

        .map-search {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
            padding-bottom: 24px;
            border-bottom: 1px solid var(--border);
        }

        .search-input {
            flex: 1;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            transition: all 0.3s ease;
        }

        .search-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(22, 105, 122, 0.1);
        }

        .legend {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 13px;
            color: var(--text-muted);
        }

        .legend-bar {
            display: flex;
            height: 20px;
            border-radius: 4px;
            overflow: hidden;
            flex: 1;
            max-width: 200px;
            background: linear-gradient(90deg, #E8F1F3, #16697A);
        }

        .filter-dropdown {
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            background-color: white;
            color: var(--text-dark);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .filter-dropdown:hover {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(22, 105, 122, 0.1);
        }

        .filter-dropdown:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(22, 105, 122, 0.1);
        }

        .action-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 24px;
            border-radius: 12px;
            border: 1.5px solid var(--border);
            background: white;
            color: var(--text-dark);
            font-family: inherit;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .action-btn:hover {
            border-color: var(--primary);
            box-shadow: 0 4px 16px rgba(22, 105, 122, 0.12);
            transform: translateY(-1px);
        }

        .action-btn-primary {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .action-btn-primary:hover {
            background: var(--primary-light);
            border-color: var(--primary-light);
        }

        .action-buttons-container {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 32px;
        }

        .share-popup {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: white;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(22, 105, 122, 0.3);
            padding: 32px;
            max-width: 400px;
            z-index: 1000;
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translate(-50%, -45%);
            }
            to {
                opacity: 1;
                transform: translate(-50%, -50%);
            }
        }

        .share-popup-close {
            position: absolute;
            top: 16px;
            right: 16px;
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: var(--text-muted);
            transition: color 0.2s;
        }

        .share-popup-close:hover {
            color: var(--text-dark);
        }

        .share-popup h3 {
            margin-bottom: 20px;
            font-size: 18px;
            color: var(--text-dark);
        }

        .share-options {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .share-option-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: white;
            color: var(--text-dark);
            font-family: inherit;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .share-option-btn:hover {
            border-color: var(--primary);
            background: var(--bg-warm);
            transform: translateX(4px);
        }

        .share-popup-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.3);
            z-index: 999;
            animation: fadeIn 0.2s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        #map-svg {
            width: 100%;
            height: 550px;
            margin-top: 24px;
            border-radius: 16px;
            overflow: hidden;
            background: #e8ecf1;
            border: 1px solid #ddd;
        }

        .leaflet-container {
            border-radius: 12px;
            font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
        }

        .leaflet-pane {
            z-index: 1;
        }

        .leaflet-control {
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }

        .map-tooltip {
            background: #16697A;
            color: white;
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 13px;
            z-index: 1000;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
            max-width: 250px;
            pointer-events: none;
        }

        .province-path {
            cursor: pointer;
            stroke: white;
            stroke-width: 1.5;
            transition: all 0.3s ease;
        }

        .province-path:hover {
            stroke-width: 2;
            filter: drop-shadow(0 2px 8px rgba(22, 105, 122, 0.3));
            opacity: 0.8;
        }

        .sidebar {
            position: fixed;
            right: 0;
            top: 0;
            width: 520px;
            height: 100vh;
            background: white;
            border-left: 1px solid var(--border);
            overflow-y: auto;
            overflow-x: hidden;
            z-index: 150;
            box-shadow: -4px 0 24px rgba(0, 0, 0, 0.06);
            transform: translateX(100%);
            transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .sidebar.open {
            transform: translateX(0);
        }

        body.sidebar-push {
            margin-right: 520px;
            transition: margin-right 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .app-layout {
            display: block;
        }

        .app-main {
            min-width: 0;
        }

        .sidebar-close {
            display: block;
            position: absolute;
            top: 24px;
            right: 24px;
            width: 32px;
            height: 32px;
            border: none;
            background: none;
            font-size: 24px;
            cursor: pointer;
            color: var(--text-muted);
            transition: color 0.3s ease;
        }

        .sidebar-close:hover {
            color: var(--text-dark);
        }

        .sidebar-content {
            padding: 24px;
            padding-top: 32px;
        }

        .sidebar-breadcrumb {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 12px;
            flex-wrap: wrap;
        }
        .sidebar-breadcrumb a {
            color: var(--primary);
            text-decoration: none;
            cursor: pointer;
            font-weight: 600;
        }
        .sidebar-breadcrumb a:hover { text-decoration: underline; }
        .sidebar-breadcrumb .bc-sep { color: var(--border); }
        .sidebar-breadcrumb .bc-current { color: var(--text-dark); font-weight: 600; }

        .sidebar-title {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            margin-bottom: 24px;
            color: var(--text-dark);
        }

        /* Kecamatan cards in sidebar */
        .kec-section-title {
            font-family: 'Instrument Serif', serif;
            font-size: 16px;
            margin-bottom: 10px;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .kec-loading {
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
            padding: 16px 0;
        }
        .kec-card {
            background: var(--bg-warm);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px 14px;
            margin-bottom: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .kec-card:hover {
            border-color: var(--primary-light);
            box-shadow: 0 2px 8px rgba(22, 105, 122, 0.10);
        }
        .kec-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }
        .kec-card-name {
            font-weight: 600;
            font-size: 13px;
            color: var(--text-dark);
        }
        .kec-card-sppg {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            font-weight: 700;
            color: var(--primary);
        }
        .kec-card-bar {
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            overflow: hidden;
            margin-bottom: 4px;
        }
        .kec-card-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
            border-radius: 2px;
            transition: width 0.5s ease;
        }
        .kec-card-meta {
            font-size: 11px;
            color: var(--text-muted);
        }

        .sidebar-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 24px;
            flex-wrap: wrap;
            border-bottom: 1px solid var(--border);
            padding-bottom: 16px;
        }

        .tab-pill {
            padding: 8px 16px;
            border-radius: 20px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-dark);
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .tab-pill.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .tab-pill:hover {
            border-color: var(--primary);
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .tab-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-light);
            font-size: 13px;
        }

        .tab-item:last-child {
            border-bottom: none;
        }

        .tab-label {
            color: var(--text-muted);
        }

        .tab-value {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            color: var(--text-dark);
        }

        footer {
            background: var(--bg-dark);
            color: rgba(255, 255, 255, 0.8);
            padding: 60px 24px 40px;
            margin-top: 80px;
        }

        .footer-content {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 40px;
            margin-bottom: 40px;
        }

        .footer-section h3 {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            margin-bottom: 16px;
            color: white;
        }

        .footer-section p {
            font-size: 13px;
            line-height: 1.8;
            margin-bottom: 12px;
        }

        .footer-links {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .footer-link {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            font-size: 13px;
            transition: color 0.3s ease;
        }

        .footer-link:hover {
            color: white;
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 24px;
            text-align: center;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.6);
        }

        /* PROGRESS MBG SECTION */
        .progress-panel {
            margin-bottom: 32px;
        }

        .progress-panel-header {
            background: linear-gradient(135deg, #16697A 0%, #489FB5 100%);
            color: white;
            padding: 20px 28px;
            border-radius: 16px 16px 0 0;
            font-family: 'Instrument Serif', 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 400;
        }

        .progress-panel-body {
            background: rgba(255, 255, 255, 0.55);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.65);
            border-top: none;
            border-radius: 0 0 16px 16px;
            padding: 28px;
            box-shadow: 0 8px 32px rgba(22, 105, 122, 0.08);
        }

        .progress-panel-desc {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 24px;
        }

        .progress-stats-6 {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 14px;
            margin-bottom: 0;
        }

        .progress-stats-4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 24px;
        }

        .p-stat-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 18px 20px;
            text-align: left;
        }

        .p-stat-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 100px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: white;
            margin-bottom: 12px;
        }

        .p-stat-badge.navy { background: #16697A; }
        .p-stat-badge.green { background: #2D6A4F; }
        .p-stat-badge.teal { background: #16697A; }
        .p-stat-badge.brown { background: #8B6914; }
        .p-stat-badge.purple { background: #5B3A8C; }
        .p-stat-badge.dark-teal { background: #0D4F5C; }
        .p-stat-badge.dark-green { background: #1B5E3B; }
        .p-stat-badge.gold { background: #9A7B2A; }

        .p-stat-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 26px;
            font-weight: 700;
            color: var(--text-dark);
            letter-spacing: -1px;
        }

        .estimation-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 16px;
            border-radius: 100px;
            background: white;
            border: 1px solid var(--border);
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            margin-bottom: 20px;
        }

        .progress-target-bar {
            background: white;
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px;
        }

        .progress-target-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .progress-target-label {
            font-size: 13px;
            color: var(--text-muted);
        }

        .progress-target-pct {
            font-family: 'JetBrains Mono', monospace;
            font-size: 18px;
            font-weight: 700;
            color: var(--primary);
        }

        .progress-bar-track {
            width: 100%;
            height: 10px;
            background: #E8EDF2;
            border-radius: 5px;
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            border-radius: 5px;
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
            transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
        }

        @media (max-width: 1024px) {
            .progress-stats-6 { grid-template-columns: repeat(3, 1fr); }
            .progress-stats-4 { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 600px) {
            .progress-stats-6 { grid-template-columns: repeat(2, 1fr); }
            .progress-stats-4 { grid-template-columns: 1fr; }
        }

        /* DETAIL PROVINSI SECTION */
        .detail-section {
            background: var(--bg-warm);
        }

        .detail-header {
            background: linear-gradient(135deg, #16697A 0%, #489FB5 100%);
            color: white;
            padding: 28px 32px;
            border-radius: 20px 20px 0 0;
            font-family: 'Instrument Serif', 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 400;
            letter-spacing: -0.5px;
        }

        .detail-body {
            background: rgba(255, 255, 255, 0.55);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.65);
            border-top: none;
            border-radius: 0 0 20px 20px;
            padding: 32px;
            box-shadow: 0 8px 32px rgba(22, 105, 122, 0.08);
        }

        .detail-desc {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 20px;
        }

        .detail-select-label {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--primary);
            margin-bottom: 8px;
        }

        /* Searchable Combobox */
        .search-combo-wrapper {
            position: relative;
            margin-bottom: 28px;
        }
        .search-combo-input {
            width: 100%;
            padding: 14px 48px 14px 44px;
            border: 1.5px solid var(--border);
            border-radius: 14px;
            font-size: 15px;
            font-family: inherit;
            background: white;
            color: var(--text-dark);
            transition: all 0.3s ease;
            outline: none;
        }
        .search-combo-input::placeholder { color: var(--text-muted); }
        .search-combo-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(22, 105, 122, 0.1);
        }
        .search-combo-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 18px;
            color: var(--text-muted);
            pointer-events: none;
        }
        .search-combo-clear {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 18px;
            color: var(--text-muted);
            cursor: pointer;
            display: none;
            background: none;
            border: none;
            padding: 4px;
            line-height: 1;
        }
        .search-combo-clear:hover { color: var(--accent-red); }
        .search-combo-dropdown {
            position: absolute;
            top: calc(100% + 6px);
            left: 0;
            right: 0;
            background: white;
            border: 1.5px solid var(--border);
            border-radius: 14px;
            max-height: 320px;
            overflow-y: auto;
            z-index: 50;
            display: none;
            box-shadow: 0 12px 40px rgba(0,0,0,0.10);
        }
        .search-combo-dropdown.open { display: block; }
        .search-combo-item {
            padding: 12px 16px;
            cursor: pointer;
            font-size: 14px;
            color: var(--text-dark);
            border-bottom: 1px solid var(--border-light);
            transition: background 0.15s;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .search-combo-item:last-child { border-bottom: none; }
        .search-combo-item:hover, .search-combo-item.active { background: rgba(22, 105, 122, 0.06); }
        .search-combo-item-sub {
            font-size: 12px;
            color: var(--text-muted);
            margin-left: auto;
        }
        .search-combo-empty {
            padding: 20px 16px;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
        }

        /* Province Overview Cards */
        .prov-overview {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 14px;
            margin-bottom: 28px;
        }
        @media (max-width: 1100px) {
            .prov-overview { grid-template-columns: repeat(3, 1fr); }
        }
        @media (max-width: 700px) {
            .prov-overview { grid-template-columns: repeat(2, 1fr); }
        }
        .prov-ov-card {
            background: white;
            border: 1.5px solid var(--border);
            border-radius: 16px;
            padding: 20px 18px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
            transition: all 0.3s ease;
        }
        .prov-ov-card:hover {
            border-color: var(--primary-light);
            box-shadow: 0 4px 20px rgba(22, 105, 122, 0.10);
            transform: translateY(-2px);
        }
        .prov-ov-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
        }
        .prov-ov-icon.dapur { background: rgba(22, 105, 122, 0.10); }
        .prov-ov-icon.penerima { background: rgba(252, 163, 17, 0.12); }
        .prov-ov-icon.harian { background: rgba(45, 106, 79, 0.10); }
        .prov-ov-icon.total { background: rgba(230, 57, 70, 0.10); }
        .prov-ov-icon.pekerja { background: rgba(72, 159, 181, 0.12); }
        .prov-ov-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 20px;
            font-weight: 700;
            color: var(--text-dark);
            line-height: 1.2;
        }
        .prov-ov-label {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
            letter-spacing: 0.2px;
        }

        .detail-select {
            display: none;
        }

        .detail-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 12px;
        }

        .detail-stats-row2 {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 32px;
        }

        .detail-stat-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px;
            transition: all 0.3s ease;
        }

        .detail-stat-card:hover {
            border-color: rgba(22, 105, 122, 0.3);
            box-shadow: 0 4px 16px rgba(22, 105, 122, 0.08);
        }

        .detail-stat-label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .detail-stat-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 28px;
            font-weight: 700;
            color: var(--text-dark);
            letter-spacing: -1px;
        }

        .detail-stat-value.accent {
            color: var(--primary);
        }

        .kab-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }

        .kab-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .kab-card:hover {
            border-color: rgba(22, 105, 122, 0.3);
            box-shadow: 0 4px 16px rgba(22, 105, 122, 0.08);
            transform: translateY(-2px);
        }

        .kab-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }

        .kab-card-name {
            font-weight: 700;
            font-size: 14px;
            color: var(--text-dark);
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .kab-card-sppg {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
            font-size: 18px;
            color: var(--text-dark);
        }

        .kab-card-bar {
            width: 100%;
            height: 6px;
            background: #E8EDF2;
            border-radius: 3px;
            overflow: hidden;
            margin-bottom: 10px;
        }

        .kab-card-bar-fill {
            height: 100%;
            border-radius: 3px;
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
            transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .kab-card-meta {
            font-size: 12px;
            color: var(--text-muted);
        }

        .detail-empty {
            text-align: center;
            padding: 48px 24px;
            color: var(--text-muted);
            font-size: 15px;
        }

        @media (max-width: 768px) {
            .detail-stats { grid-template-columns: 1fr; }
            .detail-stats-row2 { grid-template-columns: 1fr; }
            .kab-grid { grid-template-columns: 1fr; }
            .detail-stat-value { font-size: 22px; }
        }

        /* LIQUID GLASS CARDS */
        .glass {
            background: var(--glass-bg);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
        }

        /* SECTION BADGE PILL */
        .section-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 16px;
            border-radius: 100px;
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            font-size: 13px;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 16px;
            letter-spacing: 0.3px;
        }

        /* SCROLL FADE-UP ANIMATION */
        .fade-up {
            opacity: 0;
            transform: translateY(32px);
            transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .fade-up-delay-1 { transition-delay: 0.1s; }
        .fade-up-delay-2 { transition-delay: 0.2s; }
        .fade-up-delay-3 { transition-delay: 0.3s; }
        .fade-up-delay-4 { transition-delay: 0.4s; }
        .fade-up-delay-5 { transition-delay: 0.5s; }

        /* HERO CINEMATIC HEADING */
        .hero-heading {
            font-family: 'Instrument Serif', Georgia, serif;
            font-size: 52px;
            font-weight: 400;
            line-height: 1.05;
            letter-spacing: -2px;
            margin-bottom: 16px;
            color: var(--text-dark);
        }

        .hero-heading em {
            font-style: italic;
            color: var(--accent-gold);
        }

        .hero-subheading {
            font-size: 17px;
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto 40px;
            line-height: 1.7;
            font-weight: 400;
        }

        /* GRADIENT DIVIDER BETWEEN SECTIONS */
        .section-divider {
            height: 1px;
            max-width: 1400px;
            margin: 0 auto;
            background: linear-gradient(90deg, transparent, var(--border), transparent);
        }

        /* PREMIUM NAV */
        .nav-pill.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            box-shadow: 0 2px 12px rgba(22, 105, 122, 0.25);
        }

        @media (max-width: 768px) {
            .header-container { gap: 12px; padding: 12px 16px; }
            .logo { font-size: 18px; }
            nav { display: none; }
            .section-title { font-size: 28px; }
            .counter-number { font-size: 36px; }
            .summary-cards-grid { grid-template-columns: repeat(2, 1fr); }
            .sidebar { width: 100%; }
            body.sidebar-push { margin-right: 0; }
            .sidebar.open { position: fixed; z-index: 200; }
            section { padding: 48px 16px; }
            .hero-ticker { padding: 48px 16px; }
        }

        @media (max-width: 480px) {
            .summary-cards-grid { grid-template-columns: 1fr; }
            .counter-number { font-size: 28px; }
            .section-title { font-size: 24px; }
            .rate-cards { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body class="sidebar-push">
    <header>
        <div class="header-container">
            <div class="logo">📊 Manfaat MBG</div>
            <nav>
                <button class="nav-pill active" id="navDashboard" onclick="window.location.href='index.html'">Dashboard</button>
                <a href="dampak.html" class="nav-pill" id="navSustainableImpact" style="text-decoration:none;">Dampak Berkelanjutan</a>
            </nav>
            <div class="header-right" style="position: relative;">
                <button class="lang-selector" onclick="toggleLanguage()">
                    <span id="lang-flag">🇮🇩</span>
                    <span id="lang-text">Bahasa Indonesia</span>
                    <span style="font-size: 10px; margin-left: 4px;">▾</span>
                </button>
                <div class="lang-menu" id="lang-menu">
                    <div class="lang-option" onclick="switchLanguage('id')">🇮🇩 Bahasa Indonesia</div>
                    <div class="lang-option" onclick="switchLanguage('en')">🇬🇧 English</div>
                </div>
            </div>
        </div>
    </header>

    <section class="map-section" style="padding-top:32px;padding-bottom:48px;">
        <div class="container">
            <div class="section-badge fade-up">🗺️ Peta Interaktif</div>
            <h2 class="section-title fade-up" id="title-map">Sebaran SPPG Seluruh Indonesia</h2>
            <p class="section-subtitle fade-up" id="subtitle-map">Klik provinsi untuk lihat detail kabupaten/kota</p>

            <div class="map-container fade-up">
                <div class="map-search">
                    <select class="search-input" id="province-search" style="cursor:pointer;"><option value="" id="selectProvinceSearch">🔍 Pilih Provinsi...</option></select>
                    <select class="filter-dropdown" id="capaian-filter">
                        <option value="">📊 Filter Capaian: Semua</option>
                        <option value="high">>80%</option>
                        <option value="medium">50-80%</option>
